<Window x:Class="Calculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="450" Width="410"
        ResizeMode="NoResize">
    <StackPanel Margin="10">

        <TextBox x:Name="txtHistory" IsReadOnly="True" TextAlignment="Right"
                 Height="30" Margin="0,0,0,3" Foreground="Gray"/>

        <TextBox x:Name="txtCurrent" IsReadOnly="True" TextAlignment="Right"
                 Height="40" FontSize="20" Margin="0,0,0,10" Text="0"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0" Grid.Column="0" Content="C"   Click="C_Click"         Margin="3" Background="LightCoral"/>
            <Button Grid.Row="0" Grid.Column="1" Content="CE"  Click="CE_Click"        Margin="3" Background="LightCoral"/>
            <Button Grid.Row="0" Grid.Column="2" Content="&lt;" Click="Back_Click"     Margin="3" Background="LightCoral"/>
            <Button Grid.Row="0" Grid.Column="3" Content="/"   Click="Operation_Click" Margin="3" Background="LightBlue"/>

            <Button Grid.Row="1" Grid.Column="0" Content="7" Click="Digit_Click" Margin="3"/>
            <Button Grid.Row="1" Grid.Column="1" Content="8" Click="Digit_Click" Margin="3"/>
            <Button Grid.Row="1" Grid.Column="2" Content="9" Click="Digit_Click" Margin="3"/>
            <Button Grid.Row="1" Grid.Column="3" Content="*" Click="Operation_Click" Margin="3" Background="LightBlue"/>

            <Button Grid.Row="2" Grid.Column="0" Content="4" Click="Digit_Click" Margin="3"/>
            <Button Grid.Row="2" Grid.Column="1" Content="5" Click="Digit_Click" Margin="3"/>
            <Button Grid.Row="2" Grid.Column="2" Content="6" Click="Digit_Click" Margin="3"/>
            <Button Grid.Row="2" Grid.Column="3" Content="-" Click="Operation_Click" Margin="3" Background="LightBlue"/>

            <Button Grid.Row="3" Grid.Column="0" Content="1" Click="Digit_Click" Margin="3"/>
            <Button Grid.Row="3" Grid.Column="1" Content="2" Click="Digit_Click" Margin="3"/>
            <Button Grid.Row="3" Grid.Column="2" Content="3" Click="Digit_Click" Margin="3"/>
            <Button Grid.Row="3" Grid.Column="3" Content="+" Click="Operation_Click" Margin="3" Background="LightBlue"/>

            <Button Grid.Row="4" Grid.Column="0" Content="0" Click="Digit_Click" Margin="3"/>
            <Button Grid.Row="4" Grid.Column="1" Content="." Click="Dot_Click"   Margin="3"/>
            <Button Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" Content="="
                    Click="Equal_Click" Margin="3" Background="LightGreen"/>

        </Grid>
    </StackPanel>
</Window>