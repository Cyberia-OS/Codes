<Window x:Class="KeyboardTrainer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Клавиатурный тренажер" Height="560" Width="780"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp"
        Loaded="Window_Loaded">

    <StackPanel Margin="10">

        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Символов:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Slider x:Name="sliderLength"
                        Minimum="5" Maximum="30" Value="10"
                        Width="140" VerticalAlignment="Center"
                        IsSnapToTickEnabled="True" TickFrequency="1"
                        AutoToolTipPlacement="BottomRight"
                        ValueChanged="sliderLength_ValueChanged"/>
                <TextBlock x:Name="tbSliderValue" Text="10" VerticalAlignment="Center" Margin="6,0,20,0"/>
                <Button x:Name="btnStart" Content="Start" Width="65" Height="26" Margin="0,0,8,0" Click="btnStart_Click"/>
                <Button x:Name="btnStop"  Content="Stop"  Width="65" Height="26" IsEnabled="False" Click="btnStop_Click"/>
            </StackPanel>
        </Border>

        <!--Строка задания-->
        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="8" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Введите символы:" FontWeight="Bold" Margin="0,0,0,6"/>
                <WrapPanel x:Name="wpChars"/>
            </StackPanel>
        </Border>

        <!--Клавиатура -->
        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="8">
            <StackPanel HorizontalAlignment="Center">

                <!--цифры-->
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <Border x:Name="key_1" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_1" Text="1" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_2" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_2" Text="2" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_3" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_3" Text="3" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_4" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_4" Text="4" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_5" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_5" Text="5" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_6" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_6" Text="6" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_7" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_7" Text="7" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_8" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_8" Text="8" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_9" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_9" Text="9" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_0" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_0" Text="0" Style="{StaticResource KeyLabel}"/>
                    </Border>
                </StackPanel>

                <!--QWERTY-->
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <Border x:Name="key_q" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_q" Text="q" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_w" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_w" Text="w" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_e" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_e" Text="e" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_r" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_r" Text="r" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_t" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_t" Text="t" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_y" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_y" Text="y" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_u" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_u" Text="u" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_i" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_i" Text="i" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_o" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_o" Text="o" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_p" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_p" Text="p" Style="{StaticResource KeyLabel}"/>
                    </Border>
                </StackPanel>

                <!--ASDF-->
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <Border x:Name="key_caps" Style="{StaticResource KeyBorderWide}" Width="72">
                        <TextBlock Text="Caps" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_a" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_a" Text="a" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_s" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_s" Text="s" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_d" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_d" Text="d" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_f" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_f" Text="f" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_g" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_g" Text="g" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_h" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_h" Text="h" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_j" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_j" Text="j" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_k" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_k" Text="k" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_l" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_l" Text="l" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border Style="{StaticResource KeyBorderWide}" Width="72">
                        <TextBlock Text="Enter" Style="{StaticResource KeyLabel}"/>
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <Border x:Name="key_lshift" Style="{StaticResource KeyBorderWide}" Width="96">
                        <TextBlock Text="Shift" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_z" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_z" Text="z" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_x" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_x" Text="x" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_c" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_c" Text="c" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_v" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_v" Text="v" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_b" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_b" Text="b" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_n" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_n" Text="n" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border x:Name="key_m" Style="{StaticResource KeyBorder}">
                        <TextBlock x:Name="lbl_m" Text="m" Style="{StaticResource KeyLabel}"/>
                    </Border>
                    <Border Style="{StaticResource KeyBorderWide}" Width="96">
                        <TextBlock Text="Shift" Style="{StaticResource KeyLabel}"/>
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,2" HorizontalAlignment="Center">
                    <Border x:Name="key_space" Style="{StaticResource KeyBorderWide}" Width="280">
                        <TextBlock Text="Space" Style="{StaticResource KeyLabel}"/>
                    </Border>
                </StackPanel>

            </StackPanel>
        </Border>

    </StackPanel>
</Window>